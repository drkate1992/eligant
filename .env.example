# Copy to .env for local dev. For production, set these in the Vercel dashboard
# (Project → Settings → Environment Variables) — never commit real secrets.

# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# In Supabase: Project Settings → Database → Connection string.
# DATABASE_URL  = "Connection pooling" string (port 6543) used by the app at runtime.
# DIRECT_URL    = "Direct connection" string (port 5432) used for prisma db push/migrations.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with: npx auth secret"
# Local dev only; on Vercel this is derived from the deployment URL.
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# OAuth providers (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── Email / OTP delivery (Resend) ───────────────────────────────────────────
# Get an API key at resend.com. Leave SMTP_* unset so the Resend path is used.
# EMAIL_FROM must use a domain verified in Resend (or onboarding@resend.dev for tests).
RESEND_API_KEY=""
EMAIL_FROM="Unity Financial Group <no-reply@yourdomain.com>"

# ─── Feature flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_BIOMETRIC="false"
NEXT_PUBLIC_ENABLE_CRYPTO="false"

# ─── FX rates (optional; falls back to static rates if absent) ───────────────
OPEN_EXCHANGE_APP_ID=""
